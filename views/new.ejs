<!doctype html>
<html>
  <head>
    <meta charset="utf-8">
    <title>New Post</title>
    <style>body{font-family:system-ui,Segoe UI,Arial;margin:24px}label{display:block;margin-top:8px}</style>
  </head>
  <body>
    <p><a href="/">← Back</a></p>
    <h1>New Post</h1>
    <form method="post" action="/new">
      <label>Title
        <input type="text" name="title" style="width:100%" required>
      </label>
      <label>Content (Markdown)
        <textarea name="content" rows="12" style="width:100%" required></textarea>
      </label>
      <button type="submit">Create</button>
    </form>
  </body>
</html>
